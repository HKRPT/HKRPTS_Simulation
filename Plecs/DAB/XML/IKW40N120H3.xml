<?xml version="1.0" encoding="UTF-8"?>
<SemiconductorLibrary xmlns="http://www.plexim.com/xml/semiconductors/" version="1.3">
    <Package class="IGBT with Diode" vendor="Infineon" partnumber="IKW40N120H3">
        <Variables>
            <Variable>
                <Name>v</Name>
                <MinValue>0</MinValue>
                <MaxValue>1200</MaxValue>
            </Variable>
            <Variable>
                <Name>i</Name>
                <MinValue>0</MinValue>
                <MaxValue>160</MaxValue>
            </Variable>
            <Variable>
                <Name>T</Name>
                <MinValue>25</MinValue>
                <MaxValue>175</MaxValue>
            </Variable>
            <Variable>
                <Name>Rgon</Name>
                <Description>Gate (on) resistance</Description>
                <MinValue>4</MinValue>
                <MaxValue>42</MaxValue>
            </Variable>
            <Variable>
                <Name>Rgoff</Name>
                <Description>Gate (off) resistance</Description>
                <MinValue>4</MinValue>
                <MaxValue>42</MaxValue>
            </Variable>
        </Variables>
        <CustomTables>
            <Table1D>
                <Name>scale_tj_on</Name>
                <XAxis> 25 100 175</XAxis>
                <FunctionValues scale="1"> 1.0 1.18 1.375</FunctionValues>
            </Table1D>
            <Table1D>
                <Name>scale_tj_off</Name>
                <XAxis> 25 100 175</XAxis>
                <FunctionValues scale="1"> 1.0 1.58 2.16</FunctionValues>
            </Table1D>
            <Table1D>
                <Name>scale_tj_rec</Name>
                <XAxis> 25 100 175</XAxis>
                <FunctionValues scale="1"> 1.0 1.63 2.26</FunctionValues>
            </Table1D>

            <Table1D>
                <Name>scale_v</Name>
                <XAxis> 0 600 1200</XAxis>
                <FunctionValues scale="1"> 0 1.0 2.0</FunctionValues>
            </Table1D>

            <Table1D>
                <Name>scale_rg_on</Name>
                <XAxis> 4 12 42</XAxis>
                <FunctionValues scale="1"> 0.81 1.0 1.72</FunctionValues>
            </Table1D>
            <Table1D>
                <Name>scale_rg_off</Name>
                <XAxis> 4 12 42</XAxis>
                <FunctionValues scale="1"> 0.92 1.0 1.30</FunctionValues>
            </Table1D>

            <Table1D>
                <Name>e_i_on_base</Name>
                <XAxis> 0 20 40 80</XAxis>
                <FunctionValues scale="1"> 0 1.5 3.2 7.5</FunctionValues>
            </Table1D>
            <Table1D>
                <Name>e_i_off_base</Name>
                <XAxis> 0 20 40 80</XAxis>
                <FunctionValues scale="1"> 0 0.6 1.2 2.5</FunctionValues>
            </Table1D>
            <Table1D>
                <Name>e_i_rec_base</Name>
                <XAxis> 0 20 40 80</XAxis>
                <FunctionValues scale="1"> 0 0.3 0.57 1.2</FunctionValues>
            </Table1D>
        </CustomTables>

        <SemiconductorData type="IGBT with Diode">
            <TurnOnLoss>
                <ComputationMethod>Formula only</ComputationMethod>
                <Formula>max(lookup('e_i_on_base', i) * lookup('scale_v', v) * lookup('scale_tj_on', T) * lookup('scale_rg_on', Rgon) * 1e-3, 0)</Formula>
                <CurrentAxis> 0</CurrentAxis>
                <VoltageAxis> 0</VoltageAxis>
                <TemperatureAxis> 0</TemperatureAxis>
                <Energy scale="1e-3">
                    <Temperature>
                        <Voltage> 0</Voltage>
                    </Temperature>
                </Energy>
            </TurnOnLoss>
            <TurnOffLoss>
                <ComputationMethod>Formula only</ComputationMethod>
                <Formula>max(lookup('e_i_off_base', i) * lookup('scale_v', v) * lookup('scale_tj_off', T) * lookup('scale_rg_off', Rgoff) * 1e-3, 0) + max(lookup('e_i_rec_base', -i) * lookup('scale_v', v) * lookup('scale_tj_rec', T) * 1e-3, 0)</Formula>
                <CurrentAxis> 0</CurrentAxis>
                <VoltageAxis> 0</VoltageAxis>
                <TemperatureAxis> 0</TemperatureAxis>
                <Energy scale="1e-3">
                    <Temperature>
                        <Voltage> 0</Voltage>
                    </Temperature>
                </Energy>
            </TurnOffLoss>
            <ConductionLoss>
                <ComputationMethod>Table and formula</ComputationMethod>
                <Formula>v</Formula>
                <CurrentAxis> -80 -40 -20 0 20 40 80</CurrentAxis>
                <TemperatureAxis> 25 175</TemperatureAxis>
                <VoltageDrop scale="1">
                    <Temperature> -3.1 -2.4 -1.8 0 1.5 2.05 2.8</Temperature>
                    <Temperature> -3.7 -2.6 -1.85 0 1.8 2.7 4.2</Temperature>
                </VoltageDrop>
            </ConductionLoss>
        </SemiconductorData>

        <ThermalModel>
            <Branch type="Foster" convertToCauer="false">
                <RTauElement R="0.162315" Tau="0.019167"/>
                <RTauElement R="0.074055" Tau="0.003915"/>
                <RTauElement R="0.06414" Tau="0.000367"/>
                <RTauElement R="0.009999" Tau="0.339943"/>
            </Branch>
        </ThermalModel>
    </Package>
</SemiconductorLibrary>