<?xml version="1.0" encoding="UTF-8"?>
<SemiconductorLibrary xmlns="http://www.plexim.com/xml/semiconductors/" version="1.3">
    <Package class="MOSFET with Diode" vendor="Infineon" partnumber="IPT039N15N5">
        <Variables>
            <Variable>
                <Name>v</Name>
                <MinValue>0</MinValue>
                <MaxValue>150</MaxValue>
            </Variable>
            <Variable>
                <Name>i</Name>
                <MinValue>0</MinValue>
                <MaxValue>190</MaxValue>
            </Variable>
            <Variable>
                <Name>T</Name>
                <MinValue>25</MinValue>
                <MaxValue>175</MaxValue>
            </Variable>
            <Variable>
                <Name>Rgon</Name>
                <Description>Gate (on) resistance</Description>
                <MinValue>1.6</MinValue>
                <MaxValue>50</MaxValue>
            </Variable>
            <Variable>
                <Name>Rgoff</Name>
                <Description>Gate (off) resistance</Description>
                <MinValue>1.6</MinValue>
                <MaxValue>50</MaxValue>
            </Variable>
        </Variables>
        <CustomTables>
            <Table1D>
                <Name>e_tj_sw</Name>
                <XAxis> 25 100 175</XAxis>
                <FunctionValues scale="1"> 1.0 1.05 1.1</FunctionValues>
            </Table1D>
            <Table1D>
                <Name>e_tj_rec</Name>
                <XAxis> 25 100 175</XAxis>
                <FunctionValues scale="1"> 1.0 1.6 2.2</FunctionValues>
            </Table1D>
            <Table1D>
                <Name>e_v_scale</Name>
                <XAxis> 0 75 150</XAxis>
                <FunctionValues scale="1"> 0 1.0 2.2</FunctionValues>
            </Table1D>
            <Table1D>
                <Name>e_i_on_base</Name>
                <XAxis> 0 25 50 100 190</XAxis>
                <FunctionValues scale="1"> 0 4.2 8.44 18.5 42.0</FunctionValues>
            </Table1D>
            <Table1D>
                <Name>e_i_off_base</Name>
                <XAxis> 0 25 50 100 190</XAxis>
                <FunctionValues scale="1"> 0 5.0 10.13 22.0 48.0</FunctionValues>
            </Table1D>
            <Table1D>
                <Name>e_i_rec_base</Name>
                <XAxis> 0 25 50 100 190</XAxis>
                <FunctionValues scale="1"> 0 2.8 5.79 16.0 38.0</FunctionValues>
            </Table1D>
        </CustomTables>
        <SemiconductorData type="MOSFET with Diode">
            <TurnOnLoss>
                <ComputationMethod>Formula only</ComputationMethod>
                <Formula>max(lookup('e_i_on_base', i) * lookup('e_v_scale', v) * lookup('e_tj_sw', T) * 1e-6, 0)</Formula>
                <CurrentAxis> 0</CurrentAxis>
                <VoltageAxis> 0</VoltageAxis>
                <TemperatureAxis> 0</TemperatureAxis>
                <Energy scale="1e-6">
                    <Temperature>
                        <Voltage> 0</Voltage>
                    </Temperature>
                </Energy>
            </TurnOnLoss>
            <TurnOffLoss>
                <ComputationMethod>Formula only</ComputationMethod>
                <Formula>max(lookup('e_i_off_base', i) * lookup('e_v_scale', v) * lookup('e_tj_sw', T) * 1e-6, 0) + max(lookup('e_i_rec_base', -i) * lookup('e_v_scale', v) * lookup('e_tj_rec', T) * 1e-6, 0)</Formula>
                <CurrentAxis> 0</CurrentAxis>
                <VoltageAxis> 0</VoltageAxis>
                <TemperatureAxis> 0</TemperatureAxis>
                <Energy scale="1e-6">
                    <Temperature>
                        <Voltage> 0</Voltage>
                    </Temperature>
                </Energy>
            </TurnOffLoss>
            <ConductionLoss>
                <ComputationMethod>Table and formula</ComputationMethod>
                <Formula>v</Formula>
                <CurrentAxis> -190 -100 -50 0 50 100 190</CurrentAxis>
                <TemperatureAxis> 25 175</TemperatureAxis>
                <VoltageDrop scale="1">
                    <Temperature> -1.05 -0.92 -0.81 0.0 0.165 0.330 0.627</Temperature>
                    <Temperature> -0.95 -0.82 -0.70 0.0 0.380 0.760 1.444</Temperature>
                </VoltageDrop>
            </ConductionLoss>
        </SemiconductorData>
        <ThermalModel>
            <Branch type="Foster" convertToCauer="false">
                <RTauElement R="0.18" Tau="0.045"/>
                <RTauElement R="0.16" Tau="0.006"/>
                <RTauElement R="0.09" Tau="0.0008"/>
                <RTauElement R="0.04" Tau="0.00006"/>
            </Branch>
        </ThermalModel>
    </Package>
</SemiconductorLibrary>