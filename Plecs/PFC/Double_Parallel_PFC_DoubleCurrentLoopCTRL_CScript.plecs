            Value         "1"
            Show          off
          }
          Parameter {
            Variable      "RuntimeCheck"
            Value         "2"
            Show          off
          }
          Parameter {
            Variable      "Declarations"
            Value         "#define AIN  InputSignal(0,0)\n"
"#define BIN  InputSignal(0,1)\n"
"#define TWA  InputSignal(0,2)\n"
"#define TWB  InputSignal(0,3)\n"
"#define Zero InputSignal(0,4)\n"
"\n"
"#define BCH  OutputSignal(0,0)\n"
"#define BCL  OutputSignal(0,1)\n"
"#define BAH  OutputSignal(0,2)\n"
"#define BAL  OutputSignal(0,3)\n"
"#define BBH  OutputSignal(0,4)\n"
"#define BBL  OutputSignal(0,5)\n"
"\n"
"float AIn_Temp,BIn_Temp,ATW_Temp,BTW_Temp;\n"
"int Sample_Counter;\n"
"\n"
"float BCH_t,BCL_t,BAH_t,BAL_t,BBH_t,BBL_t;\n"
"\n"
"float Z,A,B;\n"
"float AC,BC;"
            Show          off
          }
          Parameter {
            Variable      "StartFcn"
            Value         "Sample_Counter=0;\n"
"AIn_Temp=0;\n"
"BIn_Temp=0;\n"
"ATW_Temp=0;\n"
"BTW_Temp=0;"
            Show          off
          }
          Parameter {
            Variable      "OutputFcn"
            Value         "if(Zero>0)Z=1;\t\n"
"else Z=0;\n"
"\n"
"\n"
"if(Z==1)AC=AIn_Temp+1;\n"
"else AC=AIn_Temp;\n"
"if(Z==1)BC=BIn_Temp+1;\n"
"else BC=BIn_Temp;\n"
"\n"
"if(AC>0.98)AC=0.98;\n"
"else if(AC<0)AC=0;\n"
"if(BC>0.98)BC=0.98;\n"
"else if(BC<0)AC=0;\n"
"\n"
"if(TWA>AC)A=1;\n"
"else A=0;\n"
"\t\n"
"if(TWB>BC)B=1;\n"
"else B=0;\n"
"\n"
"BAH = A;\n"
"BAL = (A==1)?0:1;\n"
"BBH = B;\n"
"BBL = (B==1)?0:1;\n"
"BCL = Z;\n"
"BCH = (Z==1)?0:1;\n"
            Show          off
          }
          Parameter {
            Variable      "UpdateFcn"
            Value         "Sample_Counter++;\n"
"\n"
"if(Sample_Counter==1){\n"
"\t\n"
"\tSample_Counter=0;\n"
"\tAIn_Temp=AIN;\n"
"\tBIn_Temp=BIN;\n"
"\t\n"
"\n"
"\n"
"\t\n"
"}"
            Show          off
          }
          Parameter {
            Variable      "DerivativeFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "TerminateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "StoreCustomStateFcn"
            Value         ""
            Show          off
          }
          Parameter {
            Variable      "RestoreCustomStateFcn"
            Value         ""
            Show          off
          }
