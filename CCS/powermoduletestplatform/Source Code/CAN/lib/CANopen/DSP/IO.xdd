            <UDINT />
            <q1:defaultValue value="0" />
          </q1:parameter>
          <q1:parameter uniqueID="UID_SUB_650621" access="readWrite">
            <description lang="en">过饱和前峰消影时间
过饱和1和过饱和2前沿消影时间 0:100 1:100 step= 50 63: 3300</description>
            <UDINT />
            <q1:defaultValue value="0" />
          </q1:parameter>
          <q1:parameter uniqueID="UID_SUB_650622" access="readWrite">
            <description lang="en">错误时间到门极关断延迟
错误事件到门极关断增加延迟.0-&gt;0us 1-&gt;0.263us step=0.25us 30 -&gt; 7.513us  31 -&gt; 7.763us</description>
            <UDINT />
            <q1:defaultValue value="0" />
