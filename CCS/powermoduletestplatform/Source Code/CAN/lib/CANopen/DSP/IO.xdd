            <UDINT />
            <q1:defaultValue value="0" />
          </q1:parameter>
          <q1:parameter uniqueID="UID_SUB_65061E" access="readWrite">
            <description lang="en">过饱和2 滤波时间和类型
过饱和2 滤波时间      0：NA 1-&gt;75ns step=50ns 7-&gt;375ns step=100ns 15 -&gt; 1175ns step= 200ns 23-&gt;2775ns step=400ns 31-&gt;5975ns</description>
            <UDINT />
            <q1:defaultValue value="0" />
          </q1:parameter>
          <q1:parameter uniqueID="UID_SUB_65061F" access="readWrite">
            <description lang="en">过饱和事件计数器限制值
